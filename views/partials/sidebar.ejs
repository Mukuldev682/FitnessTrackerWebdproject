<nav class="sidebar">
  <div class="sidebar-logo">FitLive</div>

  <a href="/dashboard" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
    <span class="nav-icon">📊</span> Dashboard
  </a>
  <a href="/diet" class="nav-item <%= page === 'diet' ? 'active' : '' %>">
    <span class="nav-icon">🥗</span> Diet Tracker
  </a>
  <a href="/workout" class="nav-item <%= page === 'workout' ? 'active' : '' %>">
    <span class="nav-icon">🏋️</span> Workout Tracker
  </a>
  <a href="/weight" class="nav-item <%= page === 'weight' ? 'active' : '' %>">
    <span class="nav-icon">⚖️</span> Weight & BMI
  </a>
  <a href="/goals" class="nav-item <%= page === 'goals' ? 'active' : '' %>">
