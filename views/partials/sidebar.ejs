    <span class="nav-icon">🤖</span> AI Coach
    <span style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:var(--accent);color:#000;font-size:.6rem;font-weight:700;padding:2px 6px;border-radius:10px">NEW</span>
  </a>

  <div class="nav-divider"></div>

  <a href="/googlefit" class="nav-item <%= page === 'googlefit' ? 'active' : '' %>" style="position:relative">
