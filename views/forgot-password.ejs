<%- include('partials/header', { title: 'Forgot Password' }) %>

<div class="auth-screen">
  <div class="auth-box">
    <div class="auth-logo">FitLive</div>
    <div class="auth-tagline">Reset Your Password</div>

    <%- include('partials/flash') %>

    <form action="/forgot-password" method="POST">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" required autofocus>
      </div>
      
      <p style="color:var(--muted);font-size:0.85rem;line-height:1.5;margin:15px 0;">
        Enter your email address and we'll send you a link to reset your password.
      </p>
      
      <button type="submit" class="btn-primary">Send Reset Link</button>
    </form>

    <p class="auth-footer">
      <a href="/login" style="font-size:0.85rem;color:var(--muted);">Back to Login</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
