<%- include('partials/header', { title: 'Register' }) %>

<div class="auth-screen">
  <div class="auth-box" style="max-width:500px">
    <div class="auth-logo">FitLive</div>
    <div class="auth-tagline">Create your free account</div>

    <%- include('partials/flash') %>

    <div class="tab-row">
      <a href="/login"    class="tab-btn">Login</a>
      <a href="/register" class="tab-btn active">Register</a>
    </div>

    <form action="/register" method="POST">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="name" required>
      </div>
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" minlength="6" required>
      </div>
      <div class="two-col-sm">
        <div class="form-group">
          <label>Age</label>
          <input type="number" name="age" min="1" max="120">
        </div>
        <div class="form-group">
          <label>Gender</label>
          <select name="gender">
            <option value="">Select</option>
            <option>Male</option>
            <option>Female</option>
            <option>Other</option>
          </select>
        </div>
      </div>
      <div class="two-col-sm">
        <div class="form-group">
          <label>Height (cm)</label>
          <input type="number" name="height" min="50" max="300">
        </div>
        <div class="form-group">
          <label>Weight (kg)</label>
          <input type="number" name="weight" min="10" max="500" step="0.1">
        </div>
      </div>
      <button type="submit" class="btn-primary">Create Account →</button>
    </form>

    <p class="auth-footer">
      Already have an account? <a href="/login">Login here</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
