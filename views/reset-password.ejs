<%- include('partials/header', { title: 'Reset Password' }) %>

<div class="auth-screen">
  <div class="auth-box">
    <div class="auth-logo">FitLive</div>
    <div class="auth-tagline">Set New Password</div>

    <%- include('partials/flash') %>

    <form action="/reset-password/<%= token %>" method="POST">
      <div class="form-group">
        <label>New Password</label>
        <div style="position:relative;">
          <input type="password" name="password" id="password" required minlength="6">
          <button type="button" onclick="togglePassword()" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;font-size:1.2rem;padding:5px;">
            <span id="password-toggle"> eye </span>
          </button>
        </div>
      </div>
      
      <div class="form-group">
        <label>Confirm New Password</label>
        <div style="position:relative;">
          <input type="password" name="confirmPassword" id="confirmPassword" required minlength="6">
          <button type="button" onclick="toggleConfirmPassword()" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;font-size:1.2rem;padding:5px;">
            <span id="confirm-password-toggle"> eye </span>
          </button>
        </div>
      </div>
      
      <button type="submit" class="btn-primary">Reset Password</button>
    </form>

    <p class="auth-footer">
      <a href="/login" style="font-size:0.85rem;color:var(--muted);">Back to Login</a>
    </p>
  </div>
</div>

<script>
function togglePassword() {
  const passwordInput = document.getElementById('password');
  const toggleIcon = document.getElementById('password-toggle');
  
  if (passwordInput.type === 'password') {
    passwordInput.type = 'text';
    toggleIcon.textContent = ' eye-off ';
  } else {
    passwordInput.type = 'password';
    toggleIcon.textContent = ' eye ';
  }
}

function toggleConfirmPassword() {
  const confirmPasswordInput = document.getElementById('confirmPassword');
  const toggleIcon = document.getElementById('confirm-password-toggle');
  
  if (confirmPasswordInput.type === 'password') {
    confirmPasswordInput.type = 'text';
    toggleIcon.textContent = ' eye-off ';
  } else {
    confirmPasswordInput.type = 'password';
    toggleIcon.textContent = ' eye ';
  }
}
</script>

<%- include('partials/footer') %>
