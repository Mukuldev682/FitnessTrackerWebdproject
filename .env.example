# Server Configuration
PORT=3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/fitlive

# Session
SESSION_SECRET=fitlive_super_secret_2024

# Groq API - Primary AI service
GROQ_API_KEY=your_groq_api_key_here

